# SUI Network Configuration
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC_URL=https://fullnode.testnet.sui.io

# SUI Contract Addresses (Testnet)
NEXT_PUBLIC_SHIPMENT_PACKAGE_ID=0x...
NEXT_PUBLIC_ESCROW_VAULT_OBJECT_ID=0x...
NEXT_PUBLIC_ROLE_REGISTRY_OBJECT_ID=0x...

# zkLogin & Auth
NEXT_PUBLIC_ZKLOGIN_CLIENT_ID=your_google_oauth_client_id
NEXT_PUBLIC_ZKLOGIN_PROVER_URL=https://prover.mystenlabs.com/v1
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (for zkLogin)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Slack OAuth (for zkLogin)
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/veritas

# Pinata IPFS
NEXT_PUBLIC_PINATA_GATEWAY_URL=https://your-pinata.ipfs.io
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# Email Service (e.g., Resend or SendGrid)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@veritas.app

# Notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Feature Flags
NEXT_PUBLIC_USDC_SETTLEMENT_ENABLED=true
NEXT_PUBLIC_MULTISIG_APPROVAL_ENABLED=false
NEXT_PUBLIC_CONSUMER_QR_ENABLED=false

# Admin Settings
GAS_TREASURY_SUI_CAP=10000
GAS_TREASURY_ALERT_THRESHOLD=100
EMERGENCY_PAUSE_ENABLED=false

# Logging & Monitoring
NEXT_PUBLIC_LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn
